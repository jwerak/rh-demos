# Base domain for portal routes (e.g. virt-portal.example.com)
# You need a wildcard DNS A record: *.virt-portal.example.com → <router-IP>
#
# To find the router IP:
#   dig +short console-openshift-console.$(oc get ingress.config cluster -o jsonpath='{.spec.domain}')
#
# Then create an A record in your DNS provider:
#   *.virt-portal.example.com  A  <router-IP>
#
# NOTE: Do NOT use a CNAME to apps.<cluster-domain> — the bare apps domain
# has no A record; only *.apps.<cluster-domain> resolves. Use an A record instead.
export BASE_DOMAIN=virt-portal.example.com

# Gitea admin credentials
export GITEA_ADMIN_USER=gitea-admin
export GITEA_ADMIN_PASSWORD=changeme

# RHDH backend auth secret (generate with: openssl rand -base64 32)
export BACKEND_SECRET=changeme

# Password for demo htpasswd users (admin, developer, approver, viewer)
export DEMO_PASSWORD=changeme

# Git repo URL and revision for ArgoCD (this repo)
export GITHUB_REPO=https://github.com/jwerak/rh-demos.git
export GIT_REVISION=master
