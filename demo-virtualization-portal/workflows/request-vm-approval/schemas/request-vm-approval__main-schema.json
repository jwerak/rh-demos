{
  "title": "Request VM with Approval",
  "description": "Track MR-based approval for a VM provisioning request",
  "type": "object",
  "properties": {
    "vm_name": {
      "title": "VM Name",
      "type": "string",
      "description": "Name of the virtual machine"
    },
    "environment": {
      "title": "Environment",
      "type": "string",
      "description": "Target namespace for the VM",
      "enum": ["vm-dev", "vm-staging", "vm-prod"]
    },
    "os_image": {
      "title": "OS Image",
      "type": "string",
      "description": "Operating system image"
    },
    "cpu_cores": {
      "title": "CPU Cores",
      "type": "integer",
      "description": "Number of CPU cores"
    },
    "memory_gi": {
      "title": "Memory (GiB)",
      "type": "integer",
      "description": "Memory in GiB"
    },
    "network_zone": {
      "title": "Network Zone",
      "type": "string",
      "description": "Network security zone (frontend, backend, database)",
      "enum": ["frontend", "backend", "database"]
    },
    "owner": {
      "title": "Owner",
      "type": "string",
      "description": "RHDH entity reference of the requestor"
    },
    "project_id": {
      "title": "GitLab Project ID",
      "type": "integer",
      "description": "GitLab project ID for the VM repo"
    },
    "merge_request_url": {
      "title": "Merge Request URL",
      "type": "string",
      "description": "GitLab MR URL for approval"
    }
  },
  "required": ["vm_name", "environment", "merge_request_url", "project_id"]
}
