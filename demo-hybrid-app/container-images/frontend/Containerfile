FROM registry.access.redhat.com/ubi9/nginx-124:latest

# Copy nginx configuration
COPY --chown=1001:0 nginx.conf /etc/nginx/nginx.conf.d/default.conf

# Copy static files
COPY --chown=1001:0 index.html /opt/app-root/src/

# Expose port
EXPOSE 8080

# The base image already has the correct CMD to start nginx
