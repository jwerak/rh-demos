FROM quay.io/centos/centos:stream9

# Install Python 3, pip, and build dependencies for psycopg2-binary
RUN dnf install -y python3 python3-pip python3-devel postgresql-devel gcc make && \
    dnf clean all

# Create app user and directory
RUN useradd -u 1001 -r -g 0 -m -d /app -s /sbin/nologin \
    -c "Application user" appuser && \
    mkdir -p /app && \
    chown -R 1001:0 /app && \
    chmod -R g=u /app

# Set working directory
WORKDIR /app

# Copy requirements and install dependencies
COPY --chown=1001:0 requirements.txt .
RUN python3 -m pip install --upgrade pip setuptools wheel && \
    python3 -m pip install --no-cache-dir -r requirements.txt && \
    dnf remove -y python3-devel postgresql-devel gcc make && \
    dnf clean all

# Copy application code
COPY --chown=1001:0 app.py .
RUN chmod 644 /app/app.py /app/requirements.txt && \
    chmod 755 /app

# Use non-root user
USER 1001

# Expose port
EXPOSE 8000

# Run application
CMD ["python3", "app.py"]